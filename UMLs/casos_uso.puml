@startuml
!define RECTANGLE class
title Diagrama de Casos de Uso - IDE de 8 bits

actor "Usuario\ndesarrollador" as Usuario

rectangle "IDE de 8 bits" {
  ' Casos de uso organizados verticalmente
  (Crear proyecto) as CU1
  (Abrir proyecto) as CU2
  (Guardar proyecto) as CU3
  
  (Gestionar archivos\nde código) as CU4
  
  (Compilar proyecto) as CU5
  (Visualizar errores\nde compilación) as CU6
  
  (Ejecutar programa\nen emulador) as CU7
  
  (Configurar entorno) as CU8
  (Gestionar plugins) as CU9
}

' Forzar layout vertical
CU1 -[hidden]- CU2
CU2 -[hidden]- CU3
CU3 -[hidden]- CU4
CU4 -[hidden]- CU5
CU5 -[hidden]- CU6
CU6 -[hidden]- CU7
CU7 -[hidden]- CU8
CU8 -[hidden]- CU9

' Conexiones del usuario
Usuario --> CU1
Usuario --> CU2
Usuario --> CU3
Usuario --> CU4
Usuario --> CU5
Usuario --> CU6
Usuario --> CU7
Usuario --> CU8
Usuario --> CU9

' Dependencias
CU6 ..> CU5 : «include»
CU7 ..> CU5 : «include»

@enduml